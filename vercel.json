{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": ".output/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "headers": [
    {
      "source": "/api/auth/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
