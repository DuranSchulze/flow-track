# Database (Prisma)
DATABASE_URL=

# Auth (better-auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# Google Sheets sync
# Paste the entire service-account JSON as a single line (escape newlines in private_key as \n).
# Get this from Google Cloud Console → IAM → Service Accounts → Keys → Add Key → JSON.
# Each workspace owner pastes their sheet URL in workspace settings and shares
# the sheet with the service-account email (shown in the settings panel) as Editor.
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
